generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  email     String   @unique
  password  String
  fullName  String?
  phone     String?
  address   String?
  country   String?
  city      String?
  // orders   Order[] // Поки вимкнемо, бо робимо замовлення для гостей
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    
  slug     String    @unique
  products Product[]
}

model Product {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  price       Decimal
  
  // 👇 Переконайтеся, що це поле є
  oldPrice    Decimal? 
  
  stock     Int     @default(0)
  
  imageUrl    String?
  category    Category @relation(fields: [categoryId], references: [id])
  categoryId  Int

  sizes       String[]
  availableSizes String[]
  colors      String[]
  
  // 👇 Переконайтеся, що цей зв'язок є
  variants    ProductVariant[]
  images      ProductImage[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  url       String  
  color     String? 
  
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int
}

// 👇 Переконайтеся, що ця модель додана
model ProductVariant {
  id        Int     @id @default(autoincrement())
  size      String
  color     String
  stock     Int     @default(0)
  
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int
}

// === ЗАМОВЛЕННЯ (Виправлена версія) ===
model Order {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  
  // Дані клієнта (для швидкого замовлення без реєстрації)
  customerName    String
  customerPhone   String
  customerAddress String // Місто і відділення НП
  customerEmail   String?
  shippingMethod  String   @default("NOVA") // "NOVA" або "UKR"
  paymentMethod   String   @default("COD")  // "COD" (наложка) або "CARD" (картка)
  
  status     String   @default("NEW") // NEW, SHIPPED, COMPLETED
  totalPrice Decimal

  items      OrderItem[]
}

// === ТОВАРИ В ЗАМОВЛЕННІ ===
model OrderItem {
  id        Int      @id @default(autoincrement())
  
  // Зв'язок з замовленням
  order     Order    @relation(fields: [orderId], references: [id])
  orderId   Int

  // Ми зберігаємо назву і ціну тут окремо. 
  // Це важливо: якщо ти видалиш товар з магазину, в історії замовлень він залишиться!
  productTitle String
  price        Decimal
  quantity     Int
  size         String?
  color        String?
}